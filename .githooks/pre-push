#!/usr/bin/env bash
# main への直接 push を禁止する pre-push フック（CLAUDE.md: PR 経由必須）。
# feature ブランチの push は許可する。
# 有効化: git config core.hooksPath .githooks
#
# git は pre-push を次の形で呼ぶ:
#   引数: <remote-name> <remote-url>
#   標準入力(各行): <local-ref> <local-sha> <remote-ref> <remote-sha>
set -euo pipefail

protected_branch="main"
blocked=0

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  # 削除 push も含め、宛先 ref が保護ブランチなら拒否
  if [ "$remote_ref" = "refs/heads/${protected_branch}" ]; then
    blocked=1
  fi
done

if [ "$blocked" -eq 1 ]; then
  echo "✗ pre-push: '${protected_branch}' への直接 push は禁止です（PR 経由必須）。" >&2
  echo "  作業ブランチを切って PR を出してください（CLAUDE.md 開発フロー）。" >&2
  exit 1
fi

exit 0
